# Output directory — keep the folder tracked, not the contents
output/*
!output/.gitkeep

# Resumes directory — keep the folder tracked, not the contents
resumes/*
!resumes/.gitkeep

# Prompts directory — keep the folder tracked, not the contents
prompts/*
!prompts/.gitkeep

# Python
__pycache__/
*.pyc
.env
venv/

# LaTeX build artifacts
*.aux
*.log
*.out
*.pdf
temp_resume*.tex

# Node
node_modules/

# Ignore the output directory contents, but allow the directory itself to be tracked via .gitkeep
output/*
!output/.gitkeep

# Ignore the resume directory contents, but allow the directory itself to be tracked via .gitkeep
resume/*
!resume/.gitkeep

# Ignore the prompts directory contents, but allow the directory itself to be tracked via .gitkeep
prompts/*
!prompts/.gitkeep

# Ignore python environment files
__pycache__/
*.pyc
.env

# Ignore temporary compile outputs if generated in root directory
*.aux
*.log
*.out
*.pdf
temp_resume*.tex

# Ignore venv directory
venv

